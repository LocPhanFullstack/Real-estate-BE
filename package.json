    "@types/pg": "^8.20.0",
    "@types/terraformer__wkt": "^2.0.3",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "shx": "^0.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
