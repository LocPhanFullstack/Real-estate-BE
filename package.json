    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@terraformer/wkt": "^2.2.1",
    "axios": "^1.15.2",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "uuid": "^14.0.0"
